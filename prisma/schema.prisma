generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Lead {
  id          String   @id @default(uuid())
  name        String
  phone       String
  email       String   @default("")
  city        String
  address     String
  plan        String
  status      String   @default("Nuevo")
  notes       String?
  assignedTo  String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([createdAt])
  @@index([status])
  @@index([assignedTo])
}

model Setting {
  key   String @id
  value String
}


