generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Lead {
  id        String   @id @default(uuid())
  name      String
  phone     String
  email     String   @default("")
  city      String
  address   String
  plan      String
  status    String   @default("Nuevo")
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Admin {
  id       String @id @default(uuid())
  username String @unique
  password String
}

model Setting {
  key   String @id
  value String
}


