# PostgreSQL connection string from Supabase
# IMPORTANTE: en Vercel serverless usá el Connection Pooler (puerto 6543) para no agotar conexiones.
# Ejemplo: postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"

# Supabase project URL
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT_REF].supabase.co"

# Supabase anon key (public, safe for browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY="[ANON_KEY]"

# Supabase service role key (server only, keep secret)
SUPABASE_SERVICE_ROLE_KEY="[SERVICE_ROLE_KEY]"

# Admin email for user management and default lead assignment
# (optional, defaults to admin@mundo-crm.local)
ADMIN_EMAIL="admin@mundo-crm.local"

# Upstash Redis for global rate limiting across Vercel serverless functions
# (optional but strongly recommended for production)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# SMTP config for bulk email (optional)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""
